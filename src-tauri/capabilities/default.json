{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "各窗口最小化授权（07 §4 capabilities/）",
  "windows": ["hud", "assistant", "settings", "onboarding", "home"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-start-dragging",
    "opener:default"
  ]
}
