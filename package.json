{
  "name": "typex",
  "private": true,
  "version": "0.1.0-dev",
  "packageManager": "pnpm@10.15.1",
  "type": "module",
  "license": "GPL-3.0-only",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "site:dev": "node website/scripts/sync-assets.mjs && vite --config website/vite.config.ts",
    "site:build": "node website/scripts/sync-assets.mjs && vue-tsc -p website/tsconfig.json --noEmit && vite build --config website/vite.config.ts && node website/scripts/verify-build.mjs",
    "site:preview": "vite preview --config website/vite.config.ts",
    "site:test": "vitest run --config website/vitest.config.ts",
    "tauri": "node scripts/tauri.mjs",
    "test": "vitest run",
    "gen:ipc": "cargo test --manifest-path src-tauri/Cargo.toml --no-default-features --lib export_bindings",
    "test:release-metadata": "node --test scripts/aggregate-updater-manifests.test.mjs && cargo check --locked --manifest-path tools/updater-signature-verifier/Cargo.toml",
    "verify:updater-signature": "cargo run --locked --quiet --manifest-path tools/updater-signature-verifier/Cargo.toml"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@lucide/vue": "^1.24.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-os": "^2",
    "@tauri-apps/plugin-process": "^2",
    "markdown-it": "^14",
    "pinia": "^3",
    "vue": "^3.5",
    "vue-i18n": "^11"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "@tauri-apps/cli": "^2",
    "@types/markdown-it": "^14",
    "@types/node": "^24",
    "@vitejs/plugin-vue": "^6",
    "@vue/test-utils": "^2",
    "jsdom": "^26",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5.8",
    "vite": "^7",
    "vitest": "^3",
    "vue-tsc": "^3"
  }
}
